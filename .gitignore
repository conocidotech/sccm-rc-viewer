/target
**/*.rs.bk
Cargo.lock.bak
.vscode/
.idea/
captures/*.pcapng
captures/*.cap
captures/*.pcap
!captures/.gitkeep
# Real session captures — contain authenticated traffic, never commit
*.etl
*.pcapng
experiments/capture.*

# Live-test logs (transient)
rc-*.log

# Frida capture artifacts (transient)
frida-frames.txt

# Hook/injector build artifacts (rebuild from experiments/*.c)
/hook.dll
/inject.exe

# SSPI hook capture output — decrypted session plaintext, never commit
/hook-frames.txt
experiments/captures/*.txt
# WLC desktop negotiation dumps — decrypted session content, never commit
experiments/desktop-wlc-*.txt
